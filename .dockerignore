# server 镜像 context 是仓库根(server/Dockerfile 只 COPY server/ mcp_server/ deploy/bootstrap/),
# 这里排除大体积 / 敏感 / 无关产物,缩小上传到 builder 的 context、杜绝密钥进层。
.git
.github
.venv
.venv-embedding
**/__pycache__
**/*.pyc
.env
.env.*
!.env.example
node_modules
web/node_modules
web/.next
web/dist
collector/dist
*.dist
tauri-collector
*.log
.DS_Store
.pytest_cache
.ruff_cache
